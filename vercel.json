{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "api/**",
          "app/**",
          "config/**",
          "routes/**",
          "schemas/**",
          "swagger/**",
          "package.json"
        ],
        "excludeFiles": [
          "node_modules/@types/**",
          "node_modules/**/@types/**",
          "node_modules/**/test/**",
          "node_modules/**/tests/**",
          "node_modules/**/*.test.js",
          "node_modules/**/*.spec.js",
          "node_modules/**/example/**",
          "node_modules/**/examples/**",
          "node_modules/**/docs/**",
          "node_modules/**/*.md",
          "node_modules/**/README*",
          "node_modules/**/CHANGELOG*",
          "node_modules/**/LICENSE*",
          "node_modules/**/.github/**",
          "database/migrations/**",
          "database/seeders/**",
          "test/**",
          "docs/**",
          "examples/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "buildCommand": "npm run build",
  "env": {
    "NODE_ENV": "production"
  }
}
